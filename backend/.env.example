# =============================================================================
# ESG Mefali — Backend Configuration
# Copier ce fichier en .env et renseigner les valeurs
# =============================================================================

# --- Base de données PostgreSQL ---
# Format : postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/esg_mefali

# --- Sécurité JWT ---
# Clé secrète pour signer les tokens JWT (générer une clé forte en production)
SECRET_KEY=changez-cette-cle-en-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- IA via OpenRouter ---
# Obtenir une clé sur https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# --- F08 — Attestation Vérifiable Ed25519 ---
# Clé privée Ed25519 au format PEM PKCS8 (multi-lignes encodées avec \n).
# OBLIGATOIRE en production. Bootstrap via :
#   python backend/scripts/generate_attestation_keypair.py
# En dev/tests, peut rester vide (une paire éphémère est générée).
# JAMAIS commiter cette valeur en git.
ATTESTATION_PRIVATE_KEY_PEM=
ATTESTATION_PUBLIC_KEY_ID=v1
ATTESTATION_VALIDITY_DAYS=365
ATTESTATION_VERIFICATION_BASE_URL=https://esg-mefali.com

# Environnement applicatif (development | production).
# En production, ATTESTATION_PRIVATE_KEY_PEM doit être renseignée.
ENV=development

# --- Application ---
APP_VERSION=0.1.0
DEBUG=false
