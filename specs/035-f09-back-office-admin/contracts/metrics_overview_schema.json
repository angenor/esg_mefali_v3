{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MetricsOverview",
  "description": "Réponse de GET /api/admin/metrics/overview",
  "type": "object",
  "required": ["sources", "accounts", "applications", "attestations", "llm_costs", "generated_at"],
  "properties": {
    "sources": {
      "type": "object",
      "required": ["total", "pending", "verified", "outdated", "trend_30d"],
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "pending": {"type": "integer", "minimum": 0},
        "verified": {"type": "integer", "minimum": 0},
        "outdated": {"type": "integer", "minimum": 0},
        "trend_30d": {
          "type": "array",
          "items": {"type": "integer", "minimum": 0},
          "minItems": 30,
          "maxItems": 30,
          "description": "Count par jour des transitions sur les 30 derniers jours"
        }
      }
    },
    "accounts": {
      "type": "object",
      "required": ["total_active", "total_inactive", "new_30d"],
      "properties": {
        "total_active": {"type": "integer", "minimum": 0},
        "total_inactive": {"type": "integer", "minimum": 0},
        "new_30d": {"type": "integer", "minimum": 0}
      }
    },
    "applications": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "total": {"type": "integer", "minimum": 0, "default": 0},
        "by_status": {"type": "object", "additionalProperties": {"type": "integer"}, "default": {}},
        "status": {"type": "string", "enum": ["mvp", "post_mvp"], "default": "post_mvp"}
      }
    },
    "attestations": {
      "type": "object",
      "required": ["total_emitted", "total_revoked", "total_active"],
      "properties": {
        "total_emitted": {"type": "integer", "minimum": 0},
        "total_revoked": {"type": "integer", "minimum": 0},
        "total_active": {"type": "integer", "minimum": 0}
      }
    },
    "llm_costs": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "total_tokens_in": {"type": "integer", "minimum": 0, "default": 0},
        "total_tokens_out": {"type": "integer", "minimum": 0, "default": 0},
        "total_cost_usd_estimated_30d": {"type": "number", "minimum": 0, "default": 0.0},
        "status": {"type": "string", "enum": ["mvp", "post_mvp"], "default": "post_mvp"}
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp de génération de la réponse (ISO 8601)"
    }
  }
}
